# Admin Panel Configuration
# Copy this file to .env.local and set actual values
# .env.local is git-ignored and never committed

ADMIN_PASSWORD=replace_with_your_secure_password_here

# Website chatbot (server-side only)
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
WEBSITE_BASE_URL=https://cdndayz.com

# Optional: protect analytics endpoint /api/chatbot/analytics
CHATBOT_ANALYTICS_TOKEN=replace_with_random_long_token

# Vercel KV (Redis) - Auto-populated on Vercel deployment
# These are set automatically by Vercel when you enable KV storage
# No action needed locally, but required for production saves on Vercel
# KV_URL=your_vercel_kv_url (auto-set by Vercel)
# KV_REST_API_URL=your_vercel_kv_rest_url (auto-set by Vercel)
# KV_REST_API_TOKEN=your_vercel_kv_token (auto-set by Vercel)
